# App
NODE_ENV=production
PORT=3000

# Database (required)
# Example (Neon/Supabase/Render Postgres):
# postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DATABASE_URL=

# JWT (required)
# Use a long random secret, minimum 32 chars.
JWT_SECRET=

# Frontend URL for CORS + websocket origin check
FRONTEND_URL=https://smarthub-iam-e7cdc.web.app

# Optional authz in-memory cache TTL in seconds
AUTHZ_CACHE_TTL_SECONDS=10
